{
  "name": "boss-helper",
  "displayName": "BossHelper",
  "version": "0.4.4",
  "private": true,
  "description": "Boss直聘助手, 皆在减少投递简历的麻烦, 和提高投递简历的效率,技术栈使用VIte + Vue3 + element-plus",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:edge": "wxt -b edge",
    "dev:firefox": "wxt -b firefox",
    "postinstall": "wxt prepare",
    "agent:start": "node ./scripts/agent-bootstrap.mjs",
    "agent:bridge": "node ./scripts/agent-bridge.mjs",
    "agent:stop": "node ./scripts/agent-stop.mjs",
    "agent:cli": "node ./scripts/agent-cli.mjs",
    "agent:doctor": "node ./scripts/agent-cli.mjs doctor",
    "agent:mcp": "node ./scripts/agent-mcp-server.mjs",
    "agent:bootstrap": "node ./scripts/agent-bootstrap.mjs",
    "agent:orchestrate": "node ./scripts/agent-orchestrator.mjs",
    "check": "vue-tsc --noEmit && tsc -p tsconfig.scripts.json",
    "build": "run-p build:chrome build:firefox build:edge",
    "build:chrome": "wxt build -b chrome",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "zip": "run-p zip:chrome zip:firefox zip:edge",
    "zip:chrome": "wxt zip -b chrome",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "test": "vitest run",
    "test:e2e": "pnpm build:chrome && playwright test",
    "test:e2e:headed": "pnpm build:chrome && playwright test --headed",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix"
  },
  "dependencies": {
    "@types/nanoassert": "^2.0.3",
    "axios": "^1.13.2",
    "comctx": "^1.4.3",
    "dompurify": "^3.3.3",
    "element-plus": "^2.13.0",
    "fetch-event-stream": "^0.1.6",
    "mitem": "^1.0.10",
    "nanoassert": "^2.0.0",
    "openai": "^4.104.0",
    "partial-json": "^0.1.7",
    "pinia": "^3.0.4",
    "selfsigned": "^5.5.0",
    "serialize-error": "^12.0.0",
    "vue": "^3.5.26",
    "vue-virtual-scroller": "2.0.0-beta.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.0.301",
    "@types/node": "^20.19.27",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.2",
    "@vitest/coverage-v8": "^4.1.3",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "@vueuse/core": "^14.1.0",
    "@wxt-dev/module-vue": "^1.0.3",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.3.3",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0",
    "oxlint-tsgolint": "^0.16.0",
    "proto2api": "^0.0.8",
    "protobufjs": "^7.5.4",
    "sass": "^1.97.1",
    "ts-proto": "^1.181.2",
    "typescript": "^5.9.3",
    "uid": "^2.0.2",
    "unplugin-element-plus": "^0.9.1",
    "vitest": "^4.1.3",
    "vue-tsc": "^3.2.1",
    "wxt": "^0.20.13"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint --fix"
  },
  "packageManager": "pnpm@9.12.3+sha512.cce0f9de9c5a7c95bef944169cc5dfe8741abfb145078c0d508b868056848a87c81e626246cb60967cbd7fd29a6c062ef73ff840d96b3c86c40ac92cf4a813ee"
}
